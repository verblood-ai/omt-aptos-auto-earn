# Aptos Auto Earn - Environment Variables
# Copy this file to .env and fill in the values

# === REQUIRED ===

# Aptos Network (testnet, mainnet)
APTOS_NETWORK=testnet

# Wallet Private Key (hex string, 64 characters)
# WARNING: Keep this secret! Never commit to git.
APTOS_PRIVATE_KEY=

# If APTOS_PRIVATE_KEY is empty, the app may generate a key and persist it under
# data/wallet.json (gitignored). Treat that file like a secret: chmod 600, backup
# off-box if needed. First APT should come from the faucet (README / docs/OPS.md).

# Telegram Bot Token (for notifications)
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID (where to send notifications)
TELEGRAM_CHAT_ID=

# === OPTIONAL ===

# Faucet settings
FAUCET_MAX_CLAIMS_PER_DAY=1
FAUCET_COOLDOWN_HOURS=24

# Activity settings
ACTIVITY_ENABLED=true
MIN_ACTIVITY_INTERVAL_MINUTES=30
# Comma-separated list: dex_swap,lending,nft_mint
ACTIVITY_MODULES=dex_swap
# Allow stub lending/nft modules (no real on-chain txs)
ACTIVITY_ALLOW_STUBS=false
DEX_SWAP_AMOUNT=1000000
DEX_SLIPPAGE=0.01

# Liquidswap contract overrides (optional; defaults in config/config.yaml + docs/DEX.md)
LIQUIDSWAP_ROUTER=
LIQUIDSWAP_POOL_ACCOUNT=
LIQUIDSWAP_TEST_COINS=

# Airdrop monitoring
AIRDROP_MONITOR_ENABLED=true
AIRDROP_CHECK_INTERVAL_HOURS=6
AIRDROP_APTOS_CURRENTS_URL=https://aptosfoundation.org/currents

# Aptos node / faucet overrides (optional; defaults depend on APTOS_NETWORK)
APTOS_NODE_URL=
FAUCET_API_URL=

# Testnet only: Aptos Labs кран требует JWT из сессии браузера (не «перевод с кошелька»):
# зайдите на https://aptos.dev/network/faucet → DevTools → Network → запрос mint → заголовок Authorization.
APTOS_FAUCET_JWT=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/aptos_auto_earn.log

# Metrics
METRICS_DB_PATH=data/metrics.duckdb

# Scheduler (long-lived daemon — see config/config.yaml)
# SCHEDULER_FAUCET_DAILY_AT=09:00
# SCHEDULER_ACTIVITY_INTERVAL_HOURS=6
# SCHEDULER_AIRDROP_INTERVAL_HOURS=6
# SCHEDULER_BALANCE_INTERVAL_HOURS=1

# Readiness gate
READINESS_ENABLED=true
READINESS_FAIL_MODE=closed
READINESS_SIGNAL_TTL_SECONDS=900
# Comma-separated values: rpc_health,dex_preflight,min_balance_guard,faucet_eligibility_freshness
READINESS_MANDATORY_CHECKS=rpc_health,min_balance_guard,dex_preflight
READINESS_MIN_BALANCE_APT=0.0
READINESS_REQUIRE_DEX_PREFLIGHT=true
READINESS_REQUIRE_FAUCET_ELIGIBILITY=false
READINESS_DEDUP_LOG_WINDOW_SECONDS=300

# Unified retry/backoff policies
RETRY_RPC_ATTEMPTS=3
RETRY_RPC_BASE_DELAY_SECONDS=1.0
RETRY_RPC_MAX_DELAY_SECONDS=8.0
RETRY_RPC_JITTER_RATIO=0.1
RETRY_FAUCET_ATTEMPTS=3
RETRY_FAUCET_BASE_DELAY_SECONDS=1.0
RETRY_FAUCET_MAX_DELAY_SECONDS=16.0
RETRY_FAUCET_JITTER_RATIO=0.1
RETRY_SCRAPING_ATTEMPTS=3
RETRY_SCRAPING_BASE_DELAY_SECONDS=1.0
RETRY_SCRAPING_MAX_DELAY_SECONDS=16.0
RETRY_SCRAPING_JITTER_RATIO=0.1

# KPI alerts
KPI_ALERTS_ENABLED=false
KPI_ALERTS_WINDOW_HOURS=24
KPI_ALERTS_EVAL_INTERVAL_MINUTES=30
KPI_ALERTS_COOLDOWN_MINUTES=120
# Comma-separated list:
# skip_rate,success_rate,retry_burst,faucet_claim_gap,airdrop_check_staleness
KPI_ALERTS_ENABLED_KPIS=skip_rate,success_rate,retry_burst,faucet_claim_gap,airdrop_check_staleness
KPI_SKIP_RATE_WARN=0.30
KPI_SKIP_RATE_CRITICAL=0.50
KPI_SUCCESS_RATE_WARN=0.80
KPI_SUCCESS_RATE_CRITICAL=0.60
KPI_RETRY_BURST_WARN=4
KPI_RETRY_BURST_CRITICAL=8
KPI_FAUCET_CLAIM_GAP_WARN_HOURS=30
KPI_FAUCET_CLAIM_GAP_CRITICAL_HOURS=48
KPI_AIRDROP_STALENESS_WARN_HOURS=12
KPI_AIRDROP_STALENESS_CRITICAL_HOURS=24

# Strategy/policy engine
STRATEGY_ENABLED=false
# shadow | advisory | enforcement
STRATEGY_MODE=shadow
# empty | shadow | advisory (emergency override)
STRATEGY_FORCE_MODE=
STRATEGY_ADVISORY_COOLDOWN_MINUTES=60
POLICY_ENABLED=true
POLICY_WINDOW_HOURS=24
POLICY_SKIP_BUDGET=12
POLICY_RETRY_BUDGET=8
POLICY_FAILED_RUNS_BUDGET=6
POLICY_EXECUTION_BUDGET=200
POLICY_ADVISORY_RATIO=0.85
# Comma-separated list with [0,1] ratios
POLICY_WARNING_RATIOS=0.70,0.85,0.95
